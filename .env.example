# AgroMassa environment example.
# Copy this file to .env locally and fill with real values.
# Never commit the real .env file.

# Database (Supabase PostgreSQL / Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_SECRET="replace-with-the-same-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage
# Use the base project URL only, for example:
# https://SEU-PROJETO.supabase.co
# Do not include /rest/v1 in NEXT_PUBLIC_SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-server-side-service-role-key"
SUPABASE_STORAGE_BUCKET="product-images"

# Initial administrator seed
ADMIN_NAME="AgroMassa Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Public contact defaults
AGROMASSA_WHATSAPP_DISPLAY="17 99727-8876"
AGROMASSA_WHATSAPP_DIGITS="5517997278876"
AGROMASSA_CITY="Sao Francisco"
AGROMASSA_STATE="SP"
