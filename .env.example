# Database (Supabase PostgreSQL / Prisma)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_SECRET="replace-with-the-same-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="product-images"

# Initial administrator seed
ADMIN_NAME="Administrador AgroMassa"
ADMIN_EMAIL="admin@agromassa.local"
ADMIN_PASSWORD="replace-with-a-strong-password"

# Public contact defaults
AGROMASSA_WHATSAPP_DISPLAY="17 99727-8876"
AGROMASSA_WHATSAPP_DIGITS="5517997278876"
AGROMASSA_CITY="Sao Francisco"
AGROMASSA_STATE="SP"
