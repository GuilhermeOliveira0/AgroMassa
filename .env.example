# AgroMassa environment example.
# Copy this file to .env locally and fill with environment-specific values.
# Never commit the real .env file or any production secret.

# Database (Supabase PostgreSQL / Prisma)
# Use the pooled URL for application runtime when available.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
# Use the direct database URL for migrations and maintenance commands.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_SECRET="replace-with-the-same-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage
# Use the base project URL only, for example:
# https://SEU-PROJETO.supabase.co
# Do not include /rest/v1 in NEXT_PUBLIC_SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
# Server-side secret. Never expose this value in client code.
SUPABASE_SERVICE_ROLE_KEY="replace-with-server-side-service-role-key"
# Bucket name only. The bucket must exist in Supabase Storage.
SUPABASE_STORAGE_BUCKET="product-images"

# Initial administrator seed
ADMIN_NAME="Admin Name"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Public contact defaults
AGROMASSA_WHATSAPP_DISPLAY="DD 99999-9999"
AGROMASSA_WHATSAPP_DIGITS="55DD999999999"
AGROMASSA_CITY="Cidade"
AGROMASSA_STATE="UF"
